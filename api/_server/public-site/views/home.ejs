<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
  <%- include('partials/header') %>
  <section class="hero">
    <div class="wrap">
      <h1>Custom lithium battery packs, engineered to order</h1>
      <p><%= company.tagline %>. From EV traction packs to solar OEM and LiFePO4 cells — we engineer every pack to your cell, BMS, voltage and Ah specification, with full traceability.</p>
      <a class="btn" href="/products">Browse the catalogue →</a>
    </div>
  </section>
  <main class="wrap">
    <section>
      <h2>Featured packs</h2>
      <div class="grid">
        <% products.forEach(function(p){ %>
          <a class="card" href="/products/<%= p.slug %>">
            <img src="<%= (p.images && p.images[0] && p.images[0].url) || 'https://placehold.co/600x400?text=' + encodeURIComponent(p.name) %>" alt="<%= (p.images && p.images[0] && p.images[0].alt) || p.name %>" loading="lazy" width="600" height="400" />
            <div class="body">
              <h3><%= p.name %></h3>
              <div class="specs">
                <% if (p.specs && p.specs.voltage) { %><span><%= p.specs.voltage %>V</span><% } %>
                <% if (p.specs && p.specs.ah) { %><span><%= p.specs.ah %>Ah</span><% } %>
                <% if (p.specs && p.specs.cell) { %><span><%= p.specs.cell %></span><% } %>
              </div>
              <div class="price">From ₹<%= (p.priceFrom||0).toLocaleString('en-IN') %></div>
            </div>
          </a>
        <% }) %>
        <% if (!products.length) { %><p>Catalogue coming soon.</p><% } %>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
