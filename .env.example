# ── Core ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# MongoDB (Atlas SRV or self-hosted). Password must be URL-encoded.
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/emmortal_crm?retryWrites=true&w=majority
# Only needed if your network's DNS refuses SRV lookups (querySrv ECONNREFUSED):
DNS_SERVERS=8.8.8.8,1.1.1.1

# ── Auth (use long random strings in production) ───────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TTL=15m
REFRESH_TTL=7d

# ── Public site ────────────────────────────────────────
PUBLIC_BASE_URL=https://emmortalautomotives.com

# ── Email (SMTP — leave blank to log instead of send) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@emmortalautomotives.com
LEADS_NOTIFY_EMAIL=sales@emmortalautomotives.com
BACKUP_NOTIFY_EMAIL=admin@emmortalautomotives.com

# ── Tally (live HTTP-XML gateway; blank = upload-only) ──
TALLY_HTTP_URL=
TALLY_SYNC_MODE=import        # 'import' (file upload) | 'http' (live gateway + daily cron)

# ── eSSL biometric push webhook (optional) ─────────────
ESSL_PUSH_TOKEN=

# ── Seed admin (created on first boot) ─────────────────
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@emmortal.local
SEED_ADMIN_PASSWORD=Admin@123
