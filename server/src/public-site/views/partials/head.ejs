<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= seo.title %></title>
<meta name="description" content="<%= seo.description %>" />
<% if (seo.keywords) { %><meta name="keywords" content="<%= seo.keywords %>" /><% } %>
<link rel="canonical" href="<%= seo.canonical %>" />
<meta property="og:type" content="website" />
<meta property="og:title" content="<%= seo.title %>" />
<meta property="og:description" content="<%= seo.description %>" />
<meta property="og:url" content="<%= seo.canonical %>" />
<meta name="theme-color" content="#0f766e" />
<style>
  :root { --teal:#0f766e; --dark:#0b1220; --muted:#64748b; }
  * { box-sizing:border-box; }
  body { margin:0; font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif; color:#0f172a; background:#f8fafc; line-height:1.55; }
  a { color:var(--teal); text-decoration:none; }
  .wrap { max-width:1080px; margin:0 auto; padding:0 16px; }
  header.site { background:#fff; border-bottom:1px solid #e2e8f0; position:sticky; top:0; z-index:10; }
  header.site .wrap { display:flex; align-items:center; justify-content:space-between; height:64px; }
  .brand { font-weight:800; font-size:18px; color:var(--dark); }
  nav a { margin-left:18px; font-weight:600; color:#334155; }
  nav a.btn-login { background:var(--teal); color:#fff; padding:8px 16px; border-radius:8px; }
  nav a.btn-login:hover { background:#0e7490; }
  .hero { background:linear-gradient(135deg,#0f766e,#0e7490); color:#fff; padding:64px 0; }
  .hero h1 { font-size:clamp(28px,5vw,44px); margin:0 0 12px; }
  .hero p { font-size:18px; opacity:.92; max-width:640px; }
  .btn { display:inline-block; background:#fff; color:var(--teal); font-weight:700; padding:12px 22px; border-radius:8px; margin-top:18px; }
  .btn.solid { background:var(--teal); color:#fff; }
  .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:20px; margin:32px 0; }
  .card { background:#fff; border:1px solid #e2e8f0; border-radius:12px; overflow:hidden; transition:.15s; }
  .card:hover { box-shadow:0 8px 24px rgba(2,6,23,.08); transform:translateY(-2px); }
  .card img { width:100%; height:170px; object-fit:cover; background:#e2e8f0; }
  .card .body { padding:16px; }
  .card h3 { margin:0 0 6px; font-size:17px; }
  .price { color:var(--teal); font-weight:800; }
  .specs { display:flex; flex-wrap:wrap; gap:8px; margin:12px 0; }
  .specs span { background:#ecfeff; color:#0e7490; padding:4px 10px; border-radius:999px; font-size:13px; font-weight:600; }
  section { padding:40px 0; }
  h2 { font-size:26px; }
  footer.site { background:var(--dark); color:#cbd5e1; padding:32px 0; margin-top:40px; }
  form.enquiry { background:#fff; border:1px solid #e2e8f0; border-radius:12px; padding:20px; max-width:480px; }
  form.enquiry label { display:block; font-weight:600; margin:10px 0 4px; font-size:14px; }
  form.enquiry input, form.enquiry textarea { width:100%; padding:10px; border:1px solid #cbd5e1; border-radius:8px; font:inherit; }
  .hp { position:absolute; left:-9999px; }
  .ok { color:#15803d; font-weight:700; }
</style>
