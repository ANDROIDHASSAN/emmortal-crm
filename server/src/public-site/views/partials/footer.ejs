<footer class="site">
  <div class="wrap">
    <strong><%= company.name %></strong>
    <p style="margin:8px 0; opacity:.8"><%= company.tagline %></p>
    <p style="margin:0; font-size:14px">Email: <%= company.email %> · Phone: <%= company.phone %></p>
    <p style="margin:12px 0 0; font-size:12px; opacity:.6">© <%= new Date().getFullYear() %> <%= company.name %>. All rights reserved.</p>
  </div>
</footer>
