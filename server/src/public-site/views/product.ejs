<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <script type="application/ld+json">
  { "@context":"https://schema.org", "@type":"Product", "name":"<%= product.name %>",
    "description":"<%= (product.shortDesc||'').replace(/"/g,'') %>",
    "brand":{"@type":"Brand","name":"<%= company.name %>"},
    "offers":{"@type":"Offer","priceCurrency":"INR","price":"<%= product.priceFrom||0 %>","availability":"https://schema.org/InStock"} }
  </script>
</head>
<body>
  <%- include('partials/header') %>
  <main class="wrap">
    <section>
      <a href="/products" style="font-size:14px">← Back to catalogue</a>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-top:16px;align-items:start" class="pdp">
        <div>
          <img src="<%= (product.images && product.images[0] && product.images[0].url) || 'https://placehold.co/600x400?text=' + encodeURIComponent(product.name) %>" alt="<%= product.name %>" style="width:100%;border-radius:12px;border:1px solid #e2e8f0" />
        </div>
        <div>
          <h1 style="margin-top:0"><%= product.name %></h1>
          <div class="specs">
            <% if (product.specs && product.specs.voltage) { %><span><%= product.specs.voltage %>V</span><% } %>
            <% if (product.specs && product.specs.ah) { %><span><%= product.specs.ah %>Ah</span><% } %>
            <% if (product.specs && product.specs.cell) { %><span><%= product.specs.cell %></span><% } %>
            <% if (product.specs && product.specs.bms) { %><span><%= product.specs.bms %></span><% } %>
          </div>
          <p style="color:#475569"><%= product.longDesc || product.shortDesc %></p>
          <div class="price" style="font-size:22px;margin:12px 0">From ₹<%= (product.priceFrom||0).toLocaleString('en-IN') %></div>

          <% if (sent) { %><p class="ok">✓ Thank you — your enquiry has reached E-mmortal. We'll be in touch shortly.</p><% } %>
          <form class="enquiry" method="post" action="/products/<%= product.slug %>/enquiry">
            <h3 style="margin:0 0 8px">Buy Now — request a quote</h3>
            <input class="hp" type="text" name="company_website" tabindex="-1" autocomplete="off" />
            <label>Name<input name="name" required /></label>
            <label>Phone<input name="phone" /></label>
            <label>Email<input name="email" type="email" /></label>
            <label>Quantity<input name="qty" type="number" value="1" min="1" /></label>
            <label>Message<textarea name="message" rows="2" placeholder="Tell us about your requirement"></textarea></label>
            <p style="margin-top:14px"><button class="btn solid" type="submit">Send enquiry</button></p>
          </form>
        </div>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
