# Frontend (Vercel) build-time config.
# Absolute URL of the Render backend API (note the /api/v1 suffix):
VITE_API_URL=https://emmortal-crm-api.onrender.com/api/v1
# Serve the SPA at the domain root on Vercel (single-origin local dev uses /app/):
VITE_BASE_PATH=/
# The Render backend also hosts the public storefront — used by "View site" links:
VITE_SITE_URL=https://emmortal-crm-api.onrender.com
